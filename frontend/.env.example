# EPCID Frontend Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Backend API URL (use localhost for local development)
NEXT_PUBLIC_API_URL=http://localhost:8081

# Google Gemini API Key (PRIMARY - required for AI features)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_gemini_api_key

# Groq API Key (BACKUP - optional, for failover)
# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_optional

# OpenRouter API Key (FALLBACK - optional, last resort)
OPENROUTER_API_KEY=your_openrouter_api_key_optional
